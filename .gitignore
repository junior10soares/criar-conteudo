# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
!.env.example

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# runtime data (jobs db + generated outputs)
/data/

# rhubarb lip sync binary (vendorizado via `npm run setup:rhubarb`)
/vendor/rhubarb/

# avatar 3D do usuário (ou o placeholder baixado) — ver assets/avatar/README.md
/assets/avatar/*.vrm

# estado local do Claude Code
/.claude/
