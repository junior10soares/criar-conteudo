# Pesquisa web atualizada. Opcional: funciona sem chave (tier gratuito sem login, limite mais
# baixo). Com chave (grátis, 1000 buscas/mês, sem cartão) — https://app.tavily.com
TAVILY_API_KEY=

# Geração de texto/roteiro. Por padrão é 100% GRATUITA (Pollinations.ai, sem chave, sem custo).
# Só usa Claude se as DUAS linhas abaixo estiverem preenchidas — isso é de propósito, pra nunca
# usar sem querer uma ANTHROPIC_API_KEY que já esteja no seu shell por outro motivo (ex. Claude Code).
SCRIPT_PROVIDER=
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-5

# Opcional/experimental (Fase 4): avatar com lip-sync real via um Hugging Face Space público
# (ex.: SadTalker/Wav2Lip). Formato "usuario/nome-do-space". Sem isso, ou se o Space falhar/cair,
# o app continua funcionando normalmente só com o vídeo faceless (narração + legendas + fundo).
HF_AVATAR_SPACE=
